rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for secure context evaluation
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 1. User Profiles Rule
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // 2. Individual Mood logs
    match /moods/{moodId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 3. Self-Journal note entries
    match /journals/{journalId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 4. Secure AI Chats records
    match /chats/{chatId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // 5. Shared Positive Message Board Cards
    match /community/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.likes.size() >= 0);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 6. User Specific Notification feed items
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
